{
  "version": "0.1.0",
  "license": "MIT",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=10"
  },
  "scripts": {
    "start": "heft start",
    "build": "heft build --clean",
    "prepare": "rushx build",
    "size": "size-limit",
    "analyze": "size-limit --why"
  },
  "husky": {
    "hooks": {
      "pre-commit": "tsdx lint"
    }
  },
  "prettier": {
    "printWidth": 80,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "name": "common-types",
  "author": "Aakash Shah",
  "module": "dist/common-types.esm.js",
  "size-limit": [
    {
      "path": "lib/index.js",
      "limit": "10 KB"
    }
  ],
  "devDependencies": {
    "@size-limit/preset-small-lib": "^7.0.8",
    "size-limit": "^7.0.8",
    "typescript": "^4.6.4",
    "react": "~18.1.0",
    "@types/react": "~18.0.9",
    "@types/node": "~17.0.31"
  },
  "peerDependencies": {
    "react": "~18.1.0"
  }
}
